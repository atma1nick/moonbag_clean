# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_ID=your_telegram_user_id

# Database
DATABASE_URL=sqlite+aiosqlite:///moonbag.db

# Helius (Required for wallet tracking)
# Get free key: https://helius.dev → Dashboard → API Keys
HELIUS_KEY=your_helius_key_here

# Dune Analytics (Optional — smart wallet auto-discovery)
# Get free key: https://dune.com → Settings → API Keys
DUNE_API_KEY=

# Settings
PRICE_CHECK_EVERY=60
WALLET_CHECK_EVERY=90
